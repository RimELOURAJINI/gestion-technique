{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "frontend-app": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/frontend-app",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css",
              "src/assets/assets/css/bootstrap.min.css",
              "src/assets/assets/plugins/daterangepicker/daterangepicker.css",
              "src/assets/assets/plugins/datatables/css/dataTables.bootstrap5.min.css",
              "src/assets/assets/plugins/flatpickr/flatpickr.min.css",
              "src/assets/assets/plugins/tabler-icons/tabler-icons.min.css",
              "src/assets/assets/plugins/select2/css/select2.min.css",
              "src/assets/assets/plugins/simplebar/simplebar.min.css",
              "src/assets/assets/css/style.css"
            ],
            "scripts": [
              "src/assets/assets/js/jquery-3.7.1.min.js",
              "src/assets/assets/js/bootstrap.bundle.min.js",
              "src/assets/assets/js/moment.min.js",
              "src/assets/assets/plugins/daterangepicker/daterangepicker.js",
              "src/assets/assets/plugins/apexchart/apexcharts.min.js",
              "src/assets/assets/plugins/peity/jquery.peity.min.js",
              "src/assets/assets/plugins/simplebar/simplebar.min.js",
              "src/assets/assets/plugins/select2/js/select2.min.js",
              "src/assets/assets/plugins/flatpickr/flatpickr.min.js",
              "src/assets/assets/js/theme-script.js",
              "src/assets/assets/js/script.js",
              "src/assets/assets/plugins/apexchart/chart-data.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "frontend-app:build:production"
            },
            "development": {
              "buildTarget": "frontend-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "frontend-app:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}